# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://gpu_scheduler:gpu_scheduler@localhost:5432/gpu_scheduler

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string
SESSION_EXPIRY_HOURS=72

# ── Storage Paths ─────────────────────────────────────────
UPLOAD_ROOT=/gpu_scheduler/uploads
JOBS_ROOT=/gpu_scheduler/jobs
NAS_ROOT=/mnt/nas/gpu_scheduler

# ── Container Runtime ────────────────────────────────────
CONTAINER_RUNTIME=docker
DEFAULT_CONTAINER_IMAGE=gpu-scheduler-python-gpu:latest
# GPU mode: none | nvidia
GPU_MODE=none

# ── Container Security ───────────────────────────────────
CONTAINER_USER=1000:1000
CONTAINER_READ_ONLY=true
CONTAINER_TMPFS_SIZE_MB=512
CONTAINER_LOG_MAX_SIZE=50m
CONTAINER_DISK_QUOTA=10G

# ── Scheduler ─────────────────────────────────────────────
SCHEDULER_INTERVAL_SECONDS=2
DEFAULT_QUEUE_NAME=default

# ── Worker ────────────────────────────────────────────────
WORKER_NAME=worker-01
WORKER_QUEUE=default
WORKER_HEARTBEAT_INTERVAL=10
