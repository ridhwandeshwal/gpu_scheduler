# ── Database ──────────────────────────────────────────────
# Local Postgres started via docker compose up -d
DATABASE_URL=postgresql+asyncpg://gpu_scheduler:gpu_scheduler@localhost:5432/gpu_scheduler

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string
SESSION_EXPIRY_HOURS=72

# ── Storage Paths ─────────────────────────────────────────
# Local dev: use /tmp paths so no root permissions are needed
UPLOAD_ROOT=/tmp/gpu_scheduler/uploads
JOBS_ROOT=/tmp/gpu_scheduler/jobs
NAS_ROOT=/tmp/gpu_scheduler/nas
# Workstation: use persistent paths on a large disk
# UPLOAD_ROOT=/data/gpu_scheduler/uploads
# JOBS_ROOT=/data/gpu_scheduler/jobs
# NAS_ROOT=/data/gpu_scheduler/nas

# ── MinIO (artifact storage) ─────────────────────────
# MinIO runs locally via docker compose. Change credentials before deploying.
MINIO_ENDPOINT=http://localhost:9100
# Optional: Set this to your public MinIO URL so presigned download links work in the browser.
# MINIO_PUBLIC_ENDPOINT=https://minio.quda.yourdomain.com
MINIO_ACCESS_KEY=your_minio_user          # pick any username
MINIO_SECRET_KEY=CHANGE_ME_strong_password # min 8 chars, used by docker compose + backend
MINIO_BUCKET=artifacts

# ── Container Runtime ────────────────────────────────────
CONTAINER_RUNTIME=docker
# Base image for job containers. python:3.11-slim is the default.
# Jobs install their own dependencies via requirements.txt at runtime.
DEFAULT_CONTAINER_IMAGE=python:3.11-slim
# GPU passthrough: none | nvidia
GPU_MODE=none

# Rootless Docker (no sudo required on shared workstations).
# Setup: curl -fsSL https://get.docker.com/rootless | sh
# Then:  nvidia-ctk runtime configure --runtime=docker --config=$HOME/.config/docker/daemon.json
# Find your socket with: echo $XDG_RUNTIME_DIR
# DOCKER_HOST=unix:///run/user/1000/docker.sock

# ── Container Security ───────────────────────────────────
CONTAINER_USER=1000:1000
CONTAINER_READ_ONLY=true
CONTAINER_TMPFS_SIZE_MB=512
CONTAINER_LOG_MAX_SIZE=50m
CONTAINER_DISK_QUOTA=10G

# ── Scheduler ─────────────────────────────────────────────
SCHEDULER_INTERVAL_SECONDS=2
DEFAULT_QUEUE_NAME=default

# ── Worker ────────────────────────────────────────────────
WORKER_NAME=worker-01
WORKER_QUEUE=default
WORKER_HEARTBEAT_INTERVAL=10
