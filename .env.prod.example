# ── Database ──────────────────────────────────────────────
# Local Postgres running in Docker (same compose network)
# Must match POSTGRES_USER/DB in docker-compose.prod.yml
POSTGRES_PASSWORD=CHANGE_ME_strong_password
DATABASE_URL=postgresql+asyncpg://gpu_scheduler:CHANGE_ME_strong_password@postgres:5432/gpu_scheduler

# ── Redis ─────────────────────────────────────────────────
# Internal Docker network - do not change
REDIS_URL=redis://redis:6379/0

# ── Security ──────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME
SESSION_EXPIRY_HOURS=72

# ── Storage Paths ─────────────────────────────────────────
# These map to named Docker volumes - do not change
UPLOAD_ROOT=/app/uploads
JOBS_ROOT=/app/jobs
NAS_ROOT=/app/nas

# ── MinIO (artifact storage) ──────────────────────────────
# Internal address used by api/worker containers
MINIO_ENDPOINT=http://minio:9000
# Generate password: python -c "import secrets; print(secrets.token_urlsafe(20))"
MINIO_ACCESS_KEY=quda_minio
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=artifacts

# ── Container Runtime ─────────────────────────────────────
CONTAINER_RUNTIME=docker
DEFAULT_CONTAINER_IMAGE=python:3.11-slim
CONTAINER_TMPFS_SIZE_MB=8192

# GPU mode: nvidia (RTX Titan) or none (CPU-only)
GPU_MODE=nvidia

# Rootless Docker: uncomment and set to your user's socket (find with: id -u)
# DOCKER_HOST=unix:///run/user/1000/docker.sock

# ── Scheduler ─────────────────────────────────────────────
SCHEDULER_INTERVAL_SECONDS=2
DEFAULT_QUEUE_NAME=default

# ── Worker ────────────────────────────────────────────────
WORKER_NAME=worker-lab-01
WORKER_QUEUE=default
WORKER_HEARTBEAT_INTERVAL=10

# ── Cloudflare Tunnel ─────────────────────────────────────
# 1. Go to dash.cloudflare.com - Networks - Tunnels
# 2. Create a tunnel named "quda"
# 3. Copy the token shown during setup
# 4. Add a Public Hostname pointing to http://frontend:80
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME
